{
  "functions": {
    "api/webhook.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/reminder",
      "schedule": "0 9 1 * *"
    }
  ],
  "rewrites": [
    {
      "source": "/home",
      "destination": "/landing.html"
    },
    {
      "source": "/feedback",
      "destination": "/feedback.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/app",
      "destination": "/index.html"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}